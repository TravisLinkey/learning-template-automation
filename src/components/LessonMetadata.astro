---
interface Props {
	author: string;
	date: string;
}

const { author, date } = Astro.props;

const formatDate = (dateString: string) => {
	const date = new Date(dateString);
	return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
};
---

<div class="metadata">
	<span class="metadata-item">
		<span class="metadata-icon">👤</span>
		<span class="metadata-text">
			<a href="#" class="author-link">{author}</a>
		</span>
	</span>
	<span class="metadata-separator">|</span>
	<span class="metadata-item">
		<span class="metadata-icon">📅</span>
		<span class="metadata-text">{formatDate(date)}</span>
	</span>
</div>

<style>
	.metadata {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 2rem;
		padding-bottom: 1.25rem;
		border-bottom: 1px solid #e8e8e8;
		font-size: 0.9rem;
		color: #7f8c8d;
	}

	.metadata-item {
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}

	.metadata-icon {
		font-size: 1rem;
		opacity: 0.7;
	}

	.metadata-separator {
		color: #bdc3c7;
		font-weight: 300;
	}

	.author-link {
		color: #2980b9;
		text-decoration: none;
		transition: color 0.2s;
	}

	.author-link:hover {
		color: #1f5f8b;
		text-decoration: underline;
	}

	.metadata-text {
		color: #7f8c8d;
	}
</style>

